---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Dashboard - Rebirth Hosting">
  <div class="min-h-screen bg-zinc-950 text-white">
    <div class="max-w-5xl mx-auto px-6 py-12">
      <div class="flex justify-between items-center mb-12">
        <div>
          <a href="/" class="text-2xl font-semibold tracking-tight">Rebirth Hosting</a>
        </div>
        <button id="signout" class="text-sm px-4 py-2 rounded-lg border border-zinc-700 hover:bg-zinc-900">
          Sign Out
        </button>
      </div>

      <div class="mb-8">
        <h1 class="text-4xl font-semibold tracking-tight">Welcome back</h1>
        <p class="text-zinc-400 mt-2">Your reseller dashboard</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-zinc-900 border border-zinc-800 rounded-2xl p-6">
          <div class="text-sm text-zinc-400">Domains</div>
          <div class="text-4xl font-semibold mt-2">0</div>
          <div class="text-emerald-400 text-sm mt-4">Manage domains →</div>
        </div>
        <div class="bg-zinc-900 border border-zinc-800 rounded-2xl p-6">
          <div class="text-sm text-zinc-400">Hosting Accounts</div>
          <div class="text-4xl font-semibold mt-2">0</div>
          <div class="text-emerald-400 text-sm mt-4">Manage hosting →</div>
        </div>
        <div class="bg-zinc-900 border border-zinc-800 rounded-2xl p-6">
          <div class="text-sm text-zinc-400">Balance</div>
          <div class="text-4xl font-semibold mt-2">$0.00</div>
          <div class="text-emerald-400 text-sm mt-4">Add credit →</div>
        </div>
      </div>

      <div class="mt-12 text-center text-sm text-zinc-500">
        This is a placeholder dashboard. Full features coming soon.
      </div>
    </div>
  </div>
</Layout>

<script>
  import { supabase } from '../lib/supabase';

  document.getElementById('signout')?.addEventListener('click', async () => {
    await supabase.auth.signOut();
    window.location.href = '/';
  });
</script>
