---
import Layout from '../components/Layout.astro';
import Button from '../components/Button.astro';
import Input from '../components/Input.astro';
---

<Layout title="Sign Up" showNav={true}>
  <div class="min-h-screen flex items-center justify-center pt-20 pb-12 px-6">
    <div class="max-w-md w-full">
      <!-- Header -->
      <div class="text-center mb-10">
        <div class="mx-auto w-16 h-16 bg-gradient-to-br from-amber-400 to-orange-500 rounded-3xl flex items-center justify-center mb-6 shadow-xl shadow-orange-500/20">
          <span class="text-4xl">🚀</span>
        </div>
        <h1 class="text-4xl font-bold tracking-tighter mb-3 bg-gradient-to-r from-amber-400 via-orange-500 to-amber-400 bg-clip-text text-transparent">
          Create your account
        </h1>
        <p class="text-zinc-400">Join the Rebirth Hosting reseller platform</p>
      </div>

      <!-- Form Card -->
      <div class="bg-zinc-900/70 border border-white/10 rounded-3xl p-8 shadow-2xl backdrop-blur-xl">
        <form id="signup-form" class="space-y-6">
          <Input 
            label="Full Name" 
            name="fullName" 
            placeholder="Alex Rivera" 
            required 
          />
          
          <Input 
            label="Email Address" 
            name="email" 
            type="email" 
            placeholder="you@company.com" 
            required 
          />
          
          <Input 
            label="Password" 
            name="password" 
            type="password" 
            placeholder="••••••••" 
            required 
          />

          <!-- Turnstile -->
          <div class="pt-2">
            <div id="turnstile-container" class="flex justify-center min-h-[70px]"></div>
            <p id="turnstile-status" class="text-amber-400 text-xs mt-2 text-center hidden">Verifying security...</p>
            <p id="turnstile-error" class="text-rose-400 text-xs mt-2 text-center hidden"></p>
          </div>

          <div id="form-error" class="hidden text-rose-400 text-sm text-center p-3 bg-rose-500/10 border border-rose-500/30 rounded-2xl"></div>

          <Button type="submit" id="submit-btn" disabled class="w-full py-4 text-base">
            Complete security check to continue
          </Button>
        </form>

        <div class="mt-8 text-center text-sm text-zinc-400">
          Already have an account? 
          <a href="/signin" class="text-amber-400 hover:text-amber-300 font-medium transition-colors">Sign in</a>
        </div>
      </div>

      <div class="mt-8 text-center">
        <p class="text-xs text-zinc-500">Protected by Cloudflare Turnstile</p>
      </div>
    </div>
  </div>
</Layout>

<script>
  let turnstileToken = '';
  let widgetId = null;
  let isSubmitting = false;

  const siteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;

  function showError(message) {
    const errorEl = document.getElementById('form-error');
    errorEl.textContent = message;
    errorEl.classList.remove('hidden');
  }

  function hideError() {
    const errorEl = document.getElementById('form-error');
    errorEl.classList.add('hidden');
  }

  function resetTurnstile() {
    if (typeof turnstile !== 'undefined' && widgetId) {
      turnstile.reset(widgetId);
      turnstileToken = '';
      document.getElementById('submit-btn').disabled = true;
    }
  }

  function initializeTurnstile() {
    const container = document.getElementById('turnstile-container');
    
    if (typeof turnstile === 'undefined') {
      console.warn('[Turnstile] Script not loaded yet, retrying...');
      setTimeout(initializeTurnstile, 300);
      return;
    }

    try {
      widgetId = turnstile.render(container, {
        sitekey: siteKey,
        theme: 'dark',
        size: 'normal',
        retry: 'auto',
        callback: function(token) {
          turnstileToken = token;
          document.getElementById('submit-btn').disabled = false;
          document.getElementById('turnstile-status').classList.add('hidden');
          console.log('%c✅ Turnstile verified successfully', 'color:#fbbf24; font-weight:bold');
        },
        'error-callback': function(errorCode) {
          console.error('Turnstile error:', errorCode);
          const errorEl = document.getElementById('turnstile-error');
          errorEl.textContent = 'Security check failed. Please refresh the page.';
          errorEl.classList.remove('hidden');
          document.getElementById('submit-btn').disabled = true;
        },
        'expired-callback': function() {
          console.log('Turnstile token expired');
          resetTurnstile();
        }
      });
      
      console.log('%cTurnstile widget initialized with production-ready settings', 'color:#22c55e');
    } catch (e) {
      console.error('Failed to render Turnstile:', e);
    }
  }

  // Main form handler
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('signup-form');
    const submitBtn = document.getElementById('submit-btn');
    const statusEl = document.getElementById('turnstile-status');

    // Initialize Turnstile
    initializeTurnstile();

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (isSubmitting) return;
      
      hideError();
      isSubmitting = true;
      submitBtn.disabled = true;
      submitBtn.textContent = 'Creating account...';

      const fullName = form.querySelector('[name="fullName"]').value.trim();
      const email = form.querySelector('[name="email"]').value.trim();
      const password = form.querySelector('[name="password"]').value;

      if (!email || !password) {
        showError('Please fill in all fields');
        isSubmitting = false;
        submitBtn.disabled = false;
        submitBtn.textContent = 'Create Account';
        return;
      }

      if (!turnstileToken) {
        showError('Please complete the security check');
        isSubmitting = false;
        submitBtn.disabled = false;
        submitBtn.textContent = 'Create Account';
        return;
      }

      statusEl.textContent = 'Verifying with server...';
      statusEl.classList.remove('hidden');

      try {
        const response = await fetch('/api/signup', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            fullName,
            email,
            password,
            turnstileToken
          })
        });

        const result = await response.json();

        if (!response.ok || !result.success) {
          showError(result.error || 'Signup failed');
          resetTurnstile();
          isSubmitting = false;
          submitBtn.disabled = false;
          submitBtn.textContent = 'Create Account';
          return;
        }

        // Success - redirect to check email page
        window.location.href = `/check-email?email=${encodeURIComponent(email)}`;
        
      } catch (err) {
        console.error('Signup error:', err);
        showError('Connection error. Please try again.');
        resetTurnstile();
        isSubmitting = false;
        submitBtn.disabled = false;
        submitBtn.textContent = 'Create Account';
      }
    });
  });
</script>
