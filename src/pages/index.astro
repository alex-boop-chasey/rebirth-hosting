---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Rebirth Hosting - Premium Domain & Hosting Reseller">
  <main class="min-h-screen bg-zinc-950 text-white">
    <!-- Hero Section -->
    <div class="max-w-5xl mx-auto px-6 pt-24 pb-20 text-center">
      <div class="inline-block px-4 py-1.5 rounded-full bg-zinc-900 text-sm mb-6 border border-zinc-800">
        Powered by Synergy Wholesale
      </div>

      <h1 class="text-6xl font-semibold tracking-tighter mb-6">
        Premium hosting.<br>
        <span class="text-zinc-400">Without the premium price.</span>
      </h1>

      <p class="max-w-xl mx-auto text-xl text-zinc-400 mb-10">
        Fast, reliable domain and hosting services for resellers.
        Built on Synergy Wholesale infrastructure.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/signup"
          class="inline-flex items-center justify-center px-8 py-4 rounded-xl bg-white text-black font-medium hover:bg-zinc-200 transition-colors text-lg"
        >
          Get Started
        </a>
        <a
          href="/signin"
          class="inline-flex items-center justify-center px-8 py-4 rounded-xl border border-zinc-700 hover:bg-zinc-900 transition-colors text-lg"
        >
          Sign In
        </a>
      </div>

      <p class="mt-6 text-sm text-zinc-500">
        No credit card required to start
      </p>
    </div>

    <!-- Trust / Features -->
    <div class="border-t border-zinc-800 py-12">
      <div class="max-w-5xl mx-auto px-6 grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
        <div>
          <div class="text-3xl font-semibold mb-2">99.9%</div>
          <div class="text-zinc-400">Uptime SLA</div>
        </div>
        <div>
          <div class="text-3xl font-semibold mb-2">Instant</div>
          <div class="text-zinc-400">Domain provisioning</div>
        </div>
        <div>
          <div class="text-3xl font-semibold mb-2">24/7</div>
          <div class="text-zinc-400">Support included</div>
        </div>
      </div>
    </div>
  </main>
</Layout>
