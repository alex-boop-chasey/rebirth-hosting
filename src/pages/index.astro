---
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Premium web hosting reseller platform" />
    <title>Rebirth Hosting | Web Hosting Reseller Platform</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="bg-zinc-950 text-zinc-200">
    <div class="min-h-screen flex items-center justify-center">
      <div class="max-w-2xl mx-auto text-center px-6">
        <div class="mb-8 inline-flex items-center gap-2 rounded-full bg-white/5 px-4 py-1.5 text-sm">
          <div class="w-2 h-2 bg-yellow-400 rounded-full animate-pulse"></div>
          Now in early access
        </div>
        
        <h1 class="text-7xl font-bold tracking-tighter mb-6 bg-gradient-to-r from-yellow-300 via-amber-400 to-yellow-300 bg-clip-text text-transparent">
          Rebirth Hosting
        </h1>
        
        <p class="text-xl text-zinc-400 mb-12 max-w-md mx-auto">
          The modern web hosting reseller platform. 
          White-label infrastructure for agencies and entrepreneurs.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/signup" 
             class="px-8 py-4 bg-gradient-to-r from-yellow-400 to-amber-400 text-black font-semibold rounded-2xl hover:brightness-110 transition-all active:scale-[0.985] shadow-lg shadow-yellow-400/30">
            Get Started
          </a>
          <a href="/signin" 
             class="px-8 py-4 border border-yellow-400/30 hover:bg-yellow-400/10 text-yellow-300 hover:text-yellow-200 font-medium rounded-2xl transition-all">
            Sign In
          </a>
        </div>

        <div class="mt-24 text-xs text-zinc-500 flex items-center justify-center gap-2">
          <span>Built with</span>
          <span class="text-yellow-400">Astro</span>
          <span>•</span>
          <span class="text-yellow-400">Tailwind CSS v4</span>
          <span>•</span>
          <span class="text-yellow-400">Supabase</span>
        </div>
      </div>
    </div>
  </body>
</html>
