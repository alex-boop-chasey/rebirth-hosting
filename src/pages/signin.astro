---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Sign In - Rebirth Hosting">
  <div class="min-h-screen bg-zinc-950 flex items-center justify-center px-6">
    <div class="w-full max-w-md">
      <div class="text-center mb-10">
        <a href="/" class="text-2xl font-semibold tracking-tight">Rebirth Hosting</a>
        <h1 class="mt-6 text-3xl font-semibold">Welcome back</h1>
      </div>

      <form id="signin" class="space-y-4">
        <div>
          <label class="block text-sm text-zinc-400 mb-1.5">Email address</label>
          <input
            type="email"
            name="email"
            required
            class="w-full bg-zinc-900 border border-zinc-800 rounded-xl px-4 py-3 text-white placeholder-zinc-500 focus:outline-none focus:border-zinc-600"
            placeholder="you@company.com"
          />
        </div>

        <div>
          <label class="block text-sm text-zinc-400 mb-1.5">Password</label>
          <input
            type="password"
            name="password"
            required
            class="w-full bg-zinc-900 border border-zinc-800 rounded-xl px-4 py-3 text-white placeholder-zinc-500 focus:outline-none focus:border-zinc-600"
            placeholder="••••••••"
          />
        </div>

        <button
          type="submit"
          class="w-full bg-white hover:bg-zinc-200 transition-colors text-black font-medium py-3.5 rounded-xl mt-2"
        >
          Sign In
        </button>
      </form>

      <p class="mt-8 text-center text-sm text-zinc-500">
        Don't have an account?
        <a href="/signup" class="text-white hover:underline">Create one</a>
      </p>
    </div>
  </div>
</Layout>

<script>
  import { supabase } from '../lib/supabase';

  const form = document.getElementById('signin') as HTMLFormElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const formData = new FormData(form);
    const email = formData.get('email') as string;
    const password = formData.get('password') as string;

    const { error } = await supabase.auth.signInWithPassword({
      email,
      password,
    });

    if (error) {
      alert(error.message);
      return;
    }

    // Success - redirect to dashboard
    window.location.href = '/dashboard';
  });
</script>
