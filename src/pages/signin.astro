---
import Layout from '../components/Layout.astro';

const { cookies, redirect } = Astro;
const accessToken = cookies.get("sb-access-token");
const refreshToken = cookies.get("sb-refresh-token");

if (accessToken && refreshToken) {
  return redirect('/dashboard');
}
---

<Layout title="Sign In" showNav={true}>
  <div class="min-h-screen flex items-center justify-center pt-20 pb-12 px-6">
    <div class="max-w-md w-full">
      <div class="text-center mb-10">
        <div class="mx-auto w-16 h-16 bg-gradient-to-br from-amber-400 to-orange-500 rounded-3xl flex items-center justify-center mb-6 shadow-xl shadow-orange-500/20">
          <span class="text-4xl">🔑</span>
        </div>
        <h1 class="text-4xl font-bold tracking-tighter mb-3 bg-gradient-to-r from-amber-400 via-orange-500 to-amber-400 bg-clip-text text-transparent">
          Welcome back
        </h1>
        <p class="text-zinc-400">Sign in to access your reseller dashboard</p>
      </div>

      <div class="bg-zinc-900/70 border border-white/10 rounded-3xl p-8 shadow-2xl backdrop-blur-xl">
        <form action="/api/signin" method="POST" class="space-y-6">
          <div>
            <label for="email" class="block text-sm font-medium text-zinc-400 mb-2">Email Address</label>
            <input 
              type="email" 
              name="email" 
              id="email"
              placeholder="you@company.com" 
              required
              class="w-full bg-zinc-900 border border-zinc-700 rounded-2xl px-4 py-3 text-white focus:outline-none focus:border-amber-400 transition-colors"
            />
          </div>
          
          <div>
            <label for="password" class="block text-sm font-medium text-zinc-400 mb-2">Password</label>
            <input 
              type="password" 
              name="password" 
              id="password"
              placeholder="••••••••" 
              required
              class="w-full bg-zinc-900 border border-zinc-700 rounded-2xl px-4 py-3 text-white focus:outline-none focus:border-amber-400 transition-colors"
            />
          </div>

          <button 
            type="submit"
            class="w-full bg-gradient-to-r from-amber-400 to-orange-500 text-black font-semibold py-4 rounded-2xl hover:brightness-110 transition-all"
          >
            Sign In
          </button>
        </form>

        <div class="mt-6 text-center">
          <a href="/signup" class="text-amber-400 hover:text-amber-300 text-sm font-medium transition-colors">Don't have an account? Sign up</a>
        </div>
      </div>

      <div class="mt-8 text-center">
        <p class="text-xs text-zinc-500">Secure login powered by Supabase</p>
      </div>
    </div>
  </div>
</Layout>
