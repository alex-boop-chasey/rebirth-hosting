---
interface Props {
  label: string;
  name: string;
  type?: string;
  placeholder?: string;
  required?: boolean;
  value?: string;
  class?: string;
  id?: string;
}

const { 
  label, 
  name, 
  type = 'text', 
  placeholder, 
  required = false, 
  value,
  class: className = '',
  id = name 
} = Astro.props;
---

<div class="space-y-2">
  <label for={id} class="block text-sm font-medium text-zinc-400">
    {label}
    {required && <span class="text-rose-400 ml-0.5">*</span>}
  </label>
  <input
    id={id}
    name={name}
    type={type}
    placeholder={placeholder}
    required={required}
    value={value}
    class={`w-full bg-zinc-900 border border-zinc-700 focus:border-amber-400 focus:ring-amber-400 rounded-2xl px-5 py-3.5 text-white placeholder:text-zinc-500 outline-none transition-all text-base ${className}`}
    {...Astro.props}
  />
</div>
